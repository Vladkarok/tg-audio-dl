# Before first run: mkdir -p cache && sudo chown 10001:10001 cache && chmod 750 cache
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# TELEGRAM_LOCAL_SERVER_URL is set automatically by docker-compose (http://telegram-bot-api:8081)
# Only set this manually for local development outside Docker.
# TELEGRAM_LOCAL_SERVER_URL=http://localhost:8081
CACHE_DIR=./cache
CACHE_MAX_SIZE_GB=5.0
S3_ENABLED=false
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
MAX_FILE_SIZE_MB=2000
# SECURITY: [] = allow ALL Telegram users (public bot).
# Set your Telegram user ID(s) to restrict access: ALLOWED_USER_IDS=123456,789012
ALLOWED_USER_IDS=[]
LOG_LEVEL=INFO
PLAYLIST_MAX_TRACKS=50
RATE_LIMIT_PER_MINUTE=5
DOWNLOAD_TIMEOUT_SECONDS=1800
TMP_MAX_AGE_SECONDS=3600
TMP_CLEANUP_INTERVAL_SECONDS=900
# Chapter overflow rendering. Default true: long chapter lists are sent as
# paginated pages with inline nav buttons (and /chapters is available). Set
# false to fall back to the legacy multi-message chapter index.
CHAPTER_PAGES_ENABLED=true

# Proxy for yt-dlp (required on datacenter IPs blocked by YouTube).
# Supports HTTP, HTTPS, SOCKS4, SOCKS5 proxies.
# Examples:
#   PROXY_URL=socks5://user:pass@proxy-host:1080
#   PROXY_URL=http://user:pass@proxy-host:8080
# PROXY_URL=

# Optional Netscape-format cookies file path inside the bot container.
# Leave unset unless YouTube requires account cookies for specific videos.
# COOKIES_FILE=/app/cookies.txt

# Production image selected by CI/deploy. Local development can omit this.
GHCR_IMAGE=ghcr.io/vladkarok/youtube-download-bot:latest
