# Before first run: mkdir -p cache && chmod 777 cache
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# TELEGRAM_LOCAL_SERVER_URL is set automatically by docker-compose (http://telegram-bot-api:8081)
# Only set this manually for local development outside Docker.
# TELEGRAM_LOCAL_SERVER_URL=http://localhost:8081
CACHE_DIR=./cache
CACHE_MAX_SIZE_GB=5.0
S3_ENABLED=false
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
MAX_FILE_SIZE_MB=2000
ALLOWED_USER_IDS=[]
LOG_LEVEL=INFO
PLAYLIST_MAX_TRACKS=50
RATE_LIMIT_PER_MINUTE=5

# Proxy for yt-dlp (required on datacenter IPs blocked by YouTube).
# Supports HTTP, HTTPS, SOCKS4, SOCKS5 proxies.
# Examples:
#   PROXY_URL=socks5://user:pass@proxy-host:1080
#   PROXY_URL=http://user:pass@proxy-host:8080
# PROXY_URL=
